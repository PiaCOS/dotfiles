#!/usr/bin/env bash
set -e

# --- Configuration ---
DOTFILES_DIR="$HOME/Dev/dotfiles"
CONFIG_DIR="$HOME/.config"
FONT_DIR="$HOME/.local/share/fonts"
BIN_DIR="$HOME/bin"

# --- Helper Function ---
link_item() {
    local src="$1"
    local dst="$2"

    mkdir -p "$(dirname "$dst")"

    if [ -d "$dst" ] && [ ! -L "$dst" ]; then
        echo "Removing existing directory: $dst"
        rm -rf "$dst"
    fi

    # ln -sfn: 
    # s = symbolic
    # f = force (overwrite existing links/files)
    # n = no-dereference (treat symlink to directory as a file)
    ln -sfn "$src" "$dst"
    echo "Linked: $dst -> $src"
}

# ----------------- .config Directories -----------------
link_item "$DOTFILES_DIR/fish"     "$CONFIG_DIR/fish"
link_item "$DOTFILES_DIR/helix"    "$CONFIG_DIR/helix"
link_item "$DOTFILES_DIR/wezterm"  "$CONFIG_DIR/wezterm"

# ----------------- Home Directory Files -----------------
link_item "$DOTFILES_DIR/.gitconfig" "$HOME/.gitconfig"

# ---------------------- Executables ---------------------
# link_item "$DOTFILES_DIR/scripts/my_script" "$BIN_DIR/my_script"

# ------------------------- Fonts ------------------------
if [ -d "$DOTFILES_DIR/fonts" ]; then
    mkdir -p "$FONT_DIR"
    for font in "$DOTFILES_DIR/fonts"/*; do
        link_item "$font" "$FONT_DIR/$(basename "$font")"
    done
fi

echo "All links are ready!"
