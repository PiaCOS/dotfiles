#!/usr/bin/env raku

grammar GramBranch {
    token TOP           { <remote_prefix>? <branch_name> }
    token remote_prefix { <-[:]>+ ':' }
    token branch_name   { .+ }
}

sub MAIN(Str $remote, Str $gbranch) {
    my $match = GramBranch.parse($gbranch);
    my $branch = $match<branch_name>.Str;

    run "git", "fetch", $remote, $branch;
    run "git", "switch", $branch;

    put "\nfetch+switch to $remote/$branch\n";
}
